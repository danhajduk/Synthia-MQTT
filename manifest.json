{
  "schema_version": "1.1",
  "id": "mqtt",
  "name": "Synthia MQTT",
  "description": "MQTT integration layer for Synthia Core",
  "version": "0.2.0",
  "package_profile": "standalone_service",
  "compatibility": {
    "core_min_version": "0.0.1",
    "core_max_version": null,
    "dependencies": [],
    "conflicts": []
  },
  "permissions": [
    "network.egress",
    "mqtt.publish",
    "mqtt.subscribe"
  ],
  "paths": [
    "manifest.json",
    "docker",
    "frontend",
    "app",
    "runtime",
    "requirements.txt"
  ],
  "entrypoints": {
    "service": "app/main.py",
    "ui": "frontend"
  },
  "runtime_defaults": {
    "bind_localhost": false,
    "ports": [
      {
        "host": 18080,
        "container": 8080,
        "proto": "tcp"
      }
    ]
  },
  "optional_docker_groups": [
    {
      "id": "mqtt_tools",
      "name": "MQTT Tools",
      "description": "Optional MQTT CLI helper container for diagnostics and manual inspection.",
      "compose_file": "docker/docker-compose.mqtt-tools.yml",
      "depends_on": [],
      "setup_required": false,
      "default_enabled": false
    }
  ],
  "publisher": {
    "id": "publisher.danhajduk"
  }
}
